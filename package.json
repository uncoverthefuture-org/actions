{
  "name": "@uncover/actions",
  "version": "1.0.0",
  "description": "Local container deployment system with Podman and Traefik - inspired by GitHub Actions SSH Container Deploy",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "uactions": "./bin/uactions.js",
    "ua": "./bin/uactions.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "yarn build",
    "postinstall": "node dist/scripts/postinstall.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "preinstall": "command -v yarn >/dev/null 2>&1 || echo 'This project uses yarn. Please install yarn first: npm install -g yarn'",
    "postpublish": "npm publish --access public",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "podman",
    "traefik",
    "containers",
    "deployment",
    "local-development",
    "reverse-proxy",
    "docker",
    "uactions"
  ],
  "author": "Uncover Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "chalk": "^4.1.2",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "node-fetch": "^2.7.0",
    "tar": "^6.2.0",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0",
    "zx": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/inquirer": "^9.0.7",
    "@types/tar": "^6.1.11",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node-fetch": "^2.6.11",
    "typescript": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1"
  },
  "files": [
    "dist/",
    "bin/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "preferGlobal": true,
  "preferLocal": true,
  "npx": {
    "ableToRun": true
  }
}
